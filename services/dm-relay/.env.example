# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/linkora_dm_relay

# Server Configuration
PORT=3001
NODE_ENV=development

# Security
CORS_ORIGIN=http://localhost:3000,http://localhost:8081

# Message TTL (in days)
MESSAGE_TTL_DAYS=7

# Idempotency key TTL (in hours) - how long duplicate submissions are deduped
IDEMPOTENCY_TTL_HOURS=24

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Stellar Network (for signature verification)
STELLAR_NETWORK=Testnet
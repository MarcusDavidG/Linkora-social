NODE_ENV=development

# PostgreSQL
POSTGRES_USER=linkora
POSTGRES_PASSWORD=linkora
POSTGRES_DB=linkora
DATABASE_URL=postgresql://linkora:linkora@postgres:5432/linkora

# Stellar
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
START_LEDGER=0

# Indexer API / WebSocket
PORT=3000

# Backpressure & adaptive polling (optional — defaults shown)
RPC_RATE_LIMIT_PER_SEC=10
MIN_POLL_INTERVAL_MS=100
MAX_POLL_INTERVAL_MS=5000

# Backfill / gap recovery (optional — defaults shown)
# Maximum ledgers to backfill in one recovery run. Gaps larger than this
# trigger an alert instead of an unbounded backfill.
BACKFILL_MAX_DEPTH_LEDGERS=10000
# Number of ledgers fetched per batch during backfill.
BACKFILL_BATCH_SIZE=100
# Milliseconds to wait between backfill batches (rate limiting).
BACKFILL_RATE_LIMIT_MS=100
# Emit an alert when a detected gap exceeds this many ledgers.
BACKFILL_ALERT_THRESHOLD=5000
# Stop backfilling after this many consecutive batch failures (circuit breaker).
BACKFILL_CIRCUIT_BREAKER_MAX_FAILURES=5

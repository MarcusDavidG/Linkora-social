DATABASE_URL=postgres://postgres:postgres@localhost:5432/linkora
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=
# Hex-encoded Ed25519 private key (32 bytes). Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
ORACLE_PRIVATE_KEY_HEX=
ORACLE_NAME=default
# How many ledgers between analytics computation runs (~1000 ledgers ≈ 83 min at 5s/ledger)
WINDOW_LEDGERS=1000
PORT=4000

# Per-IP rate limiting for the oracle's HTTP endpoints (see src/middleware/rate-limiter.ts)
ORACLE_RATE_LIMIT_WINDOW_MS=60000
ORACLE_RATE_LIMIT_MAX_REQUESTS=10
# Comma-separated list of IPs exempt from rate limiting (e.g. internal health checks)
ORACLE_RATE_LIMIT_BYPASS_IPS=
